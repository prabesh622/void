<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - Leveling</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% include ../layouts/navbar %>
  <div class="container">
    <div class="module-header">
      <a href="/dashboard/<%= guild.id %>" class="back-link">&larr; Back</a>
      <h2>⭐ Leveling</h2>
      <label class="toggle">
        <input type="checkbox" data-guild="<%= guild.id %>" data-feature="leveling.enabled" <%= settings.leveling?.enabled ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <div class="settings-section">
      <h3>XP Per Message</h3>
      <input type="number" class="form-input" value="<%= settings.leveling?.xpPerMessage || 20 %>" data-guild="<%= guild.id %>" data-setting="leveling.xpPerMessage" min="1" max="100">
    </div>

    <div class="settings-section">
      <h3>XP Cooldown (seconds)</h3>
      <input type="number" class="form-input" value="<%= settings.leveling?.xpCooldown || 60 %>" data-guild="<%= guild.id %>" data-setting="leveling.xpCooldown" min="10" max="300">
    </div>

    <div class="settings-section">
      <h3>Voice XP Per Minute</h3>
      <input type="number" class="form-input" value="<%= settings.leveling?.voiceXpPerMinute || 1 %>" data-guild="<%= guild.id %>" data-setting="leveling.voiceXpPerMinute" min="0" max="10">
    </div>

    <div class="settings-section">
      <h3>Level Up Message</h3>
      <p class="text-muted">Variables: {user}, {level}</p>
      <textarea class="form-textarea" data-guild="<%= guild.id %>" data-setting="leveling.levelUpMessage" rows="2"><%= settings.leveling?.levelUpMessage || '🎉 {user} just reached Level {level}!' %></textarea>
    </div>

    <div class="settings-section">
      <h3>Level Up Channel</h3>
      <select class="form-select" data-guild="<%= guild.id %>" data-setting="leveling.levelUpChannel">
        <option value="">-- Current Channel --</option>
        <% guild.channels.cache.filter(c => c.type === 0).each(ch => { %>
          <option value="<%= ch.id %>" <%= settings.leveling?.levelUpChannel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
        <% }); %>
      </select>
    </div>

    <div class="settings-section">
      <h3>Prestige System</h3>
      <label class="toggle">
        <input type="checkbox" data-guild="<%= guild.id %>" data-setting="leveling.prestige" <%= settings.leveling?.prestige ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
      <div class="form-group">
        <label>Prestige Level</label>
        <input type="number" class="form-input" value="<%= settings.leveling?.prestigeLevel || 100 %>" data-guild="<%= guild.id %>" data-setting="leveling.prestigeLevel" min="10" max="500">
      </div>
    </div>

    <div class="settings-section">
      <h3>Info</h3>
      <div class="info-box">
        <p class="text-muted">Use <code>/levelrewards</code> in Discord to configure level role rewards.</p>
      </div>
    </div>
    <button class="btn btn-primary save-btn" onclick="saveSettings('<%= guild.id %>')">Save Changes</button>
  </div>
  <script src="/js/dashboard.js"></script>
</body>
</html>
