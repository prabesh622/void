<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - Moderation</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% include ../layouts/navbar %>
  <div class="container">
    <div class="module-header">
      <a href="/dashboard/<%= guild.id %>" class="back-link">&larr; Back</a>
      <h2>🔨 Moderation</h2>
      <label class="toggle">
        <input type="checkbox" id="toggle-moderation" data-guild="<%= guild.id %>" data-feature="moderation.enabled" <%= settings.moderation?.enabled ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <div class="settings-section">
      <h3>Mod Log Channel</h3>
      <p class="text-muted">Channel where moderation actions are logged.</p>
      <select id="mod-log-channel" class="form-select" data-guild="<%= guild.id %>" data-setting="moderation.logChannel">
        <option value="">-- Select Channel --</option>
        <% guild.channels.cache.filter(c => c.type === 0).each(ch => { %>
          <option value="<%= ch.id %>" <%= settings.moderation?.logChannel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
        <% }); %>
      </select>
    </div>

    <div class="settings-section">
      <h3>DM on Action</h3>
      <p class="text-muted">Send a DM to the user when they are banned, kicked, or muted.</p>
      <label class="toggle">
        <input type="checkbox" id="toggle-dm-action" data-guild="<%= guild.id %>" data-setting="moderation.dmOnAction" <%= settings.moderation?.dmOnAction !== false ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <div class="settings-section">
      <h3>Commands</h3>
      <div class="command-list">
        <div class="command-item"><code>/ban</code> - Ban a member</div>
        <div class="command-item"><code>/kick</code> - Kick a member</div>
        <div class="command-item"><code>/mute</code> - Timeout a member</div>
        <div class="command-item"><code>/unmute</code> - Remove timeout</div>
        <div class="command-item"><code>/warn</code> - Manage warnings</div>
        <div class="command-item"><code>/purge</code> - Bulk delete messages</div>
        <div class="command-item"><code>/giverole</code> / <code>/removerole</code></div>
      </div>
    </div>
    <button class="btn btn-primary save-btn" onclick="saveSettings('<%= guild.id %>')">Save Changes</button>
  </div>
  <script src="/js/dashboard.js"></script>
</body>
</html>
