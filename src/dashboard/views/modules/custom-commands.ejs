<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - Custom Commands</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% include ../layouts/navbar %>
  <div class="container">
    <div class="module-header">
      <a href="/dashboard/<%= guild.id %>" class="back-link">&larr; Back</a>
      <h2>⚡ Custom Commands</h2>
      <label class="toggle">
        <input type="checkbox" data-guild="<%= guild.id %>" data-feature="customCommands.enabled" <%= settings.customCommands?.enabled ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <div class="settings-section">
      <h3>Info</h3>
      <div class="info-box">
        <p>Custom commands are configured via Discord commands.</p>
        <p class="text-muted">Use <code>/customcmd add</code> to create auto-responses with trigger words.</p>
        <p class="text-muted">Use <code>/customcmd list</code> to see all custom commands.</p>
        <p class="text-muted">Use <code>/customcmd remove</code> to delete a custom command.</p>
      </div>
    </div>

    <div class="settings-section">
      <h3>Variables</h3>
      <p class="text-muted">Use these in your custom command responses:</p>
      <div class="command-list">
        <div class="command-item"><code>{user}</code> - Mentions the user</div>
        <div class="command-item"><code>{username}</code> - User's name</div>
        <div class="command-item"><code>{server}</code> - Server name</div>
        <div class="command-item"><code>{membercount}</code> - Total members</div>
      </div>
    </div>

    <div class="settings-section">
      <h3>Features</h3>
      <div class="command-list">
        <div class="command-item">Exact match or regex trigger patterns</div>
        <div class="command-item">Embed or plain text responses</div>
        <div class="command-item">Per-command cooldowns</div>
      </div>
    </div>
    <button class="btn btn-primary save-btn" onclick="saveSettings('<%= guild.id %>')">Save Changes</button>
  </div>
  <script src="/js/dashboard.js"></script>
</body>
</html>
