<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - Giveaways</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% include ../layouts/navbar %>
  <div class="container">
    <div class="module-header">
      <a href="/dashboard/<%= guild.id %>" class="back-link">&larr; Back</a>
      <h2>🎉 Giveaways</h2>
      <label class="toggle">
        <input type="checkbox" data-guild="<%= guild.id %>" data-feature="giveaways.enabled" <%= settings.giveaways?.enabled ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <div class="settings-section">
      <h3>Default Duration</h3>
      <p class="text-muted">Format: 24h, 1d, 30m, etc.</p>
      <input type="text" class="form-input" value="<%= settings.giveaways?.defaultDuration || '24h' %>" data-guild="<%= guild.id %>" data-setting="giveaways.defaultDuration">
    </div>

    <div class="settings-section">
      <h3>Giveaway Emoji</h3>
      <input type="text" class="form-input" value="<%= settings.giveaways?.emoji || '🎉' %>" data-guild="<%= guild.id %>" data-setting="giveaways.emoji" maxlength="5">
    </div>

    <div class="settings-section">
      <h3>Info</h3>
      <div class="info-box">
        <p class="text-muted">Use <code>/giveaway start</code> in Discord to create giveaways with specific prizes, winners, and requirements.</p>
      </div>
    </div>
    <button class="btn btn-primary save-btn" onclick="saveSettings('<%= guild.id %>')">Save Changes</button>
  </div>
  <script src="/js/dashboard.js"></script>
</body>
</html>
