<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= guild.name %> - Economy</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% include ../layouts/navbar %>
  <div class="container">
    <div class="module-header">
      <a href="/dashboard/<%= guild.id %>" class="back-link">&larr; Back</a>
      <h2>💰 Economy</h2>
      <label class="toggle">
        <input type="checkbox" data-guild="<%= guild.id %>" data-feature="economy.enabled" <%= settings.economy?.enabled ? 'checked' : '' %>>
        <span class="toggle-slider"></span>
      </label>
    </div>

    <div class="settings-section">
      <h3>Currency Symbol</h3>
      <input type="text" class="form-input" value="<%= settings.economy?.currencySymbol || '$' %>" data-guild="<%= guild.id %>" data-setting="economy.currencySymbol" maxlength="5">
    </div>

    <div class="settings-section">
      <h3>Daily Rewards</h3>
      <div class="form-row">
        <div class="form-group">
          <label>Min Amount</label>
          <input type="number" class="form-input" value="<%= settings.economy?.dailyMin || 200 %>" data-guild="<%= guild.id %>" data-setting="economy.dailyMin" min="1">
        </div>
        <div class="form-group">
          <label>Max Amount</label>
          <input type="number" class="form-input" value="<%= settings.economy?.dailyMax || 700 %>" data-guild="<%= guild.id %>" data-setting="economy.dailyMax" min="1">
        </div>
      </div>
    </div>

    <div class="settings-section">
      <h3>Daily Cooldown (ms)</h3>
      <p class="text-muted">Default: 86400000 (24 hours)</p>
      <input type="number" class="form-input" value="<%= settings.economy?.dailyCooldown || 86400000 %>" data-guild="<%= guild.id %>" data-setting="economy.dailyCooldown" min="60000">
    </div>

    <div class="settings-section">
      <h3>Work Cooldown (ms)</h3>
      <p class="text-muted">Default: 7200000 (2 hours)</p>
      <input type="number" class="form-input" value="<%= settings.economy?.workCooldown || 7200000 %>" data-guild="<%= guild.id %>" data-setting="economy.workCooldown" min="60000">
    </div>

    <div class="settings-section">
      <h3>Log Channel</h3>
      <select class="form-select" data-guild="<%= guild.id %>" data-setting="economy.logChannel">
        <option value="">-- Select Channel --</option>
        <% guild.channels.cache.filter(c => c.type === 0).each(ch => { %>
          <option value="<%= ch.id %>" <%= settings.economy?.logChannel === ch.id ? 'selected' : '' %>>#<%= ch.name %></option>
        <% }); %>
      </select>
    </div>
    <button class="btn btn-primary save-btn" onclick="saveSettings('<%= guild.id %>')">Save Changes</button>
  </div>
  <script src="/js/dashboard.js"></script>
</body>
</html>
