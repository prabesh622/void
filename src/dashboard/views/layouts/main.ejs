<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Void Bot Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">Void Bot</div>
    <div class="nav-links">
      <% if (user) { %>
        <span class="nav-user"><img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="" width="24" class="avatar"> <%= user.username %></span>
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <a href="/logout" class="nav-link">Logout</a>
      <% } else { %>
        <a href="/auth/login" class="nav-link">Login</a>
      <% } %>
    </div>
  </nav>
  <main class="container">
    <%- body %>
  </main>
  <footer class="footer">
    <p>Void Bot Dashboard &copy; 2024</p>
  </footer>
  <script src="/js/dashboard.js"></script>
</body>
</html>
