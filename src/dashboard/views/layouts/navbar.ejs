<nav class="navbar">
  <div class="nav-brand">
    <a href="/dashboard">Void Bot</a>
  </div>
  <div class="nav-links">
    <% if (typeof user !== 'undefined' && user) { %>
      <span class="nav-user">
        <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" alt="" width="24" class="avatar">
        <%= user.username %>
      </span>
      <a href="/dashboard" class="nav-link">Servers</a>
      <a href="/logout" class="nav-link">Logout</a>
    <% } else { %>
      <a href="/auth/login" class="nav-link">Login</a>
    <% } %>
  </div>
</nav>
